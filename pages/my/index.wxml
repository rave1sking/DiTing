<view class="my-page">
  <!-- 头部信息 -->
  <view class="my-page__header">
    <view class="my-page__avatar-wrap" bindtap="onLogin">
      <image
        wx:if="{{userInfo.avatarUrl}}"
        class="my-page__avatar"
        src="{{userInfo.avatarUrl}}"
        mode="aspectFill"
      />
      <view wx:else class="my-page__avatar-default">
        <image src="/static/images/diting-avatar.svg" mode="aspectFit" class="my-page__avatar-icon" />
      </view>
    </view>
    <view class="my-page__user-info">
      <text class="my-page__nickname" bindtap="onLogin">
        {{userInfo.nickName || '点击登录'}}
      </text>
      <view class="my-page__lingli" bindtap="goLingli">
        <text class="my-page__lingli-label">灵力值</text>
        <text class="my-page__lingli-value">{{lingliBalance}}</text>
        <text class="my-page__lingli-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="my-page__grid">
    <view class="my-page__grid-item" bindtap="goHistory">
      <text class="my-page__grid-icon">📜</text>
      <text class="my-page__grid-label">历史报告</text>
    </view>
    <view class="my-page__grid-item" bindtap="goMembership">
      <text class="my-page__grid-icon">👑</text>
      <text class="my-page__grid-label">听听守护者</text>
    </view>
    <view class="my-page__grid-item" bindtap="goLingli">
      <text class="my-page__grid-icon">✨</text>
      <text class="my-page__grid-label">灵力值</text>
    </view>
    <view class="my-page__grid-item" bindtap="onShare">
      <text class="my-page__grid-icon">🎁</text>
      <text class="my-page__grid-label">邀请好友</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="my-page__menu">
    <view class="my-page__menu-item" bindtap="goHistory">
      <text class="my-page__menu-text">我的报告</text>
      <text class="my-page__menu-arrow">></text>
    </view>
    <view class="my-page__menu-item" bindtap="goMembership">
      <text class="my-page__menu-text">会员中心</text>
      <text class="my-page__menu-arrow">></text>
    </view>
    <view class="my-page__menu-item" bindtap="goSetting">
      <text class="my-page__menu-text">设置</text>
      <text class="my-page__menu-arrow">></text>
    </view>
    <view class="my-page__menu-item">
      <t-button size="small" variant="text" open-type="contact" class="my-page__menu-contact">
        联系客服
      </t-button>
      <text class="my-page__menu-arrow">></text>
    </view>
  </view>
</view>
